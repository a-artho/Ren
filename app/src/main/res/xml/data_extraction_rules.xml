<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="plan_generation.xml" />
        <exclude domain="database" path="ren-study-projects.db" />
        <exclude domain="database" path="ren-study-projects.db-shm" />
        <exclude domain="database" path="ren-study-projects.db-wal" />
        <!-- TODO: Use <include> and <exclude> to control what is backed up.
        <include .../>
        <exclude .../>
        -->
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="plan_generation.xml" />
        <exclude domain="database" path="ren-study-projects.db" />
        <exclude domain="database" path="ren-study-projects.db-shm" />
        <exclude domain="database" path="ren-study-projects.db-wal" />
    </device-transfer>
</data-extraction-rules>
